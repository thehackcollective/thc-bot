# Copy to .env and fill. .env is gitignored — never commit real values.

# OpenAI (rotate the key Louis shared; paste the NEW one here)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Which WhatsApp group chats to scan (comma-separated names or JIDs).
# Leave blank to scan all groups. Example: General,AI Builders,Startup Events
# Example: WA_GROUPS=120363428450088201@g.us THC community "General" group (🗣)
WA_GROUPS=

# How far back to look on first run
INGEST_SINCE_DAYS=14

# Luma target calendar URL (test on YOUR OWN calendar first, not THC's live one)
LUMA_CALENDAR_URL=https://luma.com/your-test-calendar

# Review dashboard port
REVIEW_PORT=3000
