{
  "name": "thc-bot",
  "version": "0.1.0",
  "private": true,
  "description": "WhatsApp -> Luma event-lead collator for The Hack Collective",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "ingest": "tsx src/cli.ts ingest",
    "extract": "tsx src/cli.ts extract",
    "run": "tsx src/cli.ts run",
    "watch": "tsx src/cli.ts watch",
    "review": "tsx src/cli.ts review",
    "login": "tsx src/cli.ts login",
    "publish": "tsx src/cli.ts publish",
    "export": "tsx src/cli.ts export",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@browserbasehq/stagehand": "^3.0.0",
    "better-sqlite3": "^11.8.0",
    "dotenv": "^16.4.7",
    "openai": "^4.77.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "allowScripts": {
    "better-sqlite3@11.10.0": true,
    "esbuild@0.28.1": true
  }
}
