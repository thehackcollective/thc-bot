# Dashboard authentication. Copy to .env.local and fill in.
# Sign/verify secret for session cookies. Use a long random value:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Super admin, seeded on first run ONLY if the users table is empty.
# After first login, manage users from the Admins page and change this password.
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=change-me
